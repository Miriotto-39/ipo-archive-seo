---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { seo } from "@/lib/seo";

const meta = seo.staticPage("免責事項", "IPOアーカイブの掲載情報、投資判断、アフィリエイトリンクに関する免責事項です。");
---

<BaseLayout title={meta.title} description={meta.description} canonical="/disclaimer/" breadcrumbs={[{ name: "ホーム", url: "/" }, { name: "免責事項", url: "/disclaimer/" }]}>
  <section class="prose-page mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-bold">免責事項</h1>
    <p class="mt-5 text-muted">掲載情報は投資勧誘ではありません。投資判断は利用者自身の責任で行ってください。</p>
    <p class="mt-4 text-muted">データの正確性や完全性は保証しません。最終確認は各社の公式URL、取引所、証券会社の公開情報で行ってください。</p>
    <p class="mt-4 text-muted">一部リンクは将来的にアフィリエイトリンクへ差し替える可能性があります。</p>
  </section>
</BaseLayout>
