---
import AffiliateBlock from "@/components/AffiliateBlock.astro";
import BrokerBadge from "@/components/BrokerBadge.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate, formatOku, formatPct, formatYen, monthOf, yearOf } from "@/lib/format";
import { loadIpos } from "@/lib/load-ipo";
import { seo } from "@/lib/seo";
import { toSlug } from "@/lib/slug";
import type { IpoRecord } from "@/lib/types";
import { withBase } from "@/lib/url";

export async function getStaticPaths() {
  const ipos = await loadIpos();
  return ipos.map((ipo) => ({ params: { code: ipo.code }, props: { ipo, allIpos: ipos } }));
}

const { ipo, allIpos } = Astro.props as { ipo: IpoRecord; allIpos: IpoRecord[] };
const meta = seo.ipo(ipo);
const year = yearOf(ipo.listing_date);
const month = monthOf(ipo.listing_date);
const marketSlug = ipo.market ? toSlug(ipo.market) : null;

const issuePriceText = ipo.issue_price != null ? formatYen(ipo.issue_price) : "情報取得中";
const initialPriceText = ipo.initial_price != null ? formatYen(ipo.initial_price) : "情報取得中";
const leadManagerText = ipo.lead_manager ?? "情報取得中";

const sameMonthIpos = allIpos.filter(
  (other) =>
    other.code !== ipo.code &&
    yearOf(other.listing_date) === year &&
    monthOf(other.listing_date) === month
).slice(0, 6);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: `${ipo.name}の上場日はいつですか？`,
      acceptedAnswer: { "@type": "Answer", text: `${ipo.name}の上場日は${formatDate(ipo.listing_date)}です。` }
    },
    {
      "@type": "Question",
      name: `${ipo.name}の公募価格と初値はいくらですか？`,
      acceptedAnswer: { "@type": "Answer", text: `公募価格は${issuePriceText}、初値は${initialPriceText}です。最新の確定情報は公式IRや株探などでご確認ください。` }
    },
    {
      "@type": "Question",
      name: `${ipo.name}の主幹事証券はどこですか？`,
      acceptedAnswer: { "@type": "Answer", text: `主幹事証券は${leadManagerText}です。` }
    }
  ]
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={`/ipo/${ipo.code}/`}
  breadcrumbs={[
    { name: "ホーム", url: "/" },
    { name: ipo.name, url: `/ipo/${ipo.code}/` }
  ]}
  extraJsonLd={faqJsonLd}
>
  <article class="mx-auto max-w-6xl px-4 py-10">
    <div class="rounded-lg border border-line bg-white p-6 shadow-soft">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-muted">{ipo.code}</p>
          <h1 class="mt-2 text-3xl font-bold">{ipo.name} IPO情報</h1>
          {ipo.business && <p class="mt-3 max-w-3xl leading-8 text-muted">{ipo.business}</p>}
        </div>
        <BrokerBadge name={ipo.lead_manager} slug={ipo.lead_manager_slug} />
      </div>
      <dl class="mt-8 grid gap-4 md:grid-cols-4">
        <div class="rounded-lg bg-paper p-4">
          <dt class="text-sm text-muted">上場日</dt>
          <dd class="mt-1 font-bold">{formatDate(ipo.listing_date)}</dd>
        </div>
        <div class="rounded-lg bg-paper p-4">
          <dt class="text-sm text-muted">市場</dt>
          <dd class="mt-1 font-bold">
            {ipo.market && marketSlug ? (
              <a href={withBase(`/market/${marketSlug}/`)}>{ipo.market}</a>
            ) : (
              <span class="text-muted">未登録</span>
            )}
          </dd>
        </div>
        <div class="rounded-lg bg-paper p-4">
          <dt class="text-sm text-muted">公募価格</dt>
          <dd class="mt-1 font-bold">{ipo.issue_price != null ? formatYen(ipo.issue_price) : <span class="text-muted text-sm">取得中</span>}</dd>
        </div>
        <div class="rounded-lg bg-paper p-4">
          <dt class="text-sm text-muted">初値騰落率</dt>
          <dd class={`mt-1 font-bold ${ipo.initial_return_pct == null ? "text-muted" : (ipo.initial_return_pct >= 0 ? "text-gain" : "text-loss")}`}>
            {ipo.initial_return_pct != null ? formatPct(ipo.initial_return_pct) : <span class="text-muted text-sm">取得中</span>}
          </dd>
        </div>
      </dl>
    </div>
    <section class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-lg border border-line bg-white p-6">
        <h2 class="text-xl font-bold">価格・需給</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between gap-4"><dt class="text-muted">仮条件</dt><dd>{formatYen(ipo.price_band_low)} - {formatYen(ipo.price_band_high)}</dd></div>
          <div class="flex justify-between gap-4"><dt class="text-muted">初値</dt><dd>{formatYen(ipo.initial_price)}</dd></div>
          <div class="flex justify-between gap-4"><dt class="text-muted">吸収金額</dt><dd>{formatOku(ipo.absorption_oku)}</dd></div>
        </dl>
        {ipo.source_urls && ipo.source_urls.length > 0 && (
          <div class="mt-5 border-t border-line pt-4">
            <p class="text-xs text-muted">最新の確定情報は外部ソースでご確認ください:</p>
            <ul class="mt-2 space-y-1 text-xs text-brand">
              {ipo.source_urls.map((url) => (
                <li><a class="underline" href={url} target="_blank" rel="noopener noreferrer">{new URL(url).hostname}</a></li>
              ))}
            </ul>
          </div>
        )}
      </div>
      <div class="rounded-lg border border-line bg-white p-6">
        <h2 class="text-xl font-bold">関連IPO・カテゴリ</h2>
        <div class="mt-4 flex flex-wrap gap-3 text-sm text-brand">
          <a href={withBase(`/year/${year}/`)}>{year}年IPO</a>
          <a href={withBase(`/year/${year}/${month}/`)}>{year}年{month}月IPO</a>
          {ipo.lead_manager_slug && <a href={withBase(`/broker/${ipo.lead_manager_slug}/`)}>{ipo.lead_manager}のIPO実績</a>}
          {ipo.sector_slug && <a href={withBase(`/sector/${ipo.sector_slug}/`)}>{ipo.sector}IPO</a>}
          {ipo.market && marketSlug && <a href={withBase(`/market/${marketSlug}/`)}>{ipo.market}IPO</a>}
        </div>
        {sameMonthIpos.length > 0 && (
          <div class="mt-6 border-t border-line pt-4">
            <h3 class="text-sm font-bold">同月の他のIPO</h3>
            <ul class="mt-2 space-y-1 text-sm">
              {sameMonthIpos.map((other) => (
                <li>
                  <a class="text-brand hover:underline" href={withBase(`/ipo/${other.code}/`)}>
                    {other.code} {other.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
    <div class="mt-8">
      <AffiliateBlock ipo={ipo} />
    </div>
  </article>
</BaseLayout>
