# 静的サイトのため必須環境変数はなし。
# 将来的にビルド時メタを差し込む場合はここに追加。

# サイトのベースURL（OGP / canonical / sitemap で使用）
PUBLIC_SITE_URL=https://ipo-archive.pages.dev

# 解析タグ（Cloudflare Web Analytics 等、後で追加する場合）
# PUBLIC_CF_ANALYTICS_TOKEN=

# データ取得用（必要になったら）
# USER_AGENT="IpoArchiveBot/0.1 (+https://ipo-archive.pages.dev/about)"
